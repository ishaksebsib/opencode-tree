{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@ishaksebsib/opencode-tree",
  "version": "0.4.2",
  "description": "Pi-style /tree plugin for OpenCode TUI.",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    }
  },
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build": "bun run scripts/build.ts",
    "typecheck": "bun x tsc -p tsconfig.json",
    "test": "bun test",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.48",
    "solid-js": "^1.9.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opentui/core": "0.2.6",
    "@opentui/keymap": "0.2.6",
    "@opentui/solid": "0.2.6",
    "@types/bun": "latest",
    "oxfmt": "^0.46.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@opentui/core": ">=0.2.6",
    "@opentui/keymap": ">=0.2.6",
    "@opentui/solid": ">=0.2.6"
  },
  "peerDependenciesMeta": {
    "@opentui/core": {
      "optional": true
    },
    "@opentui/keymap": {
      "optional": true
    },
    "@opentui/solid": {
      "optional": true
    }
  },
  "engines": {
    "opencode": "^1.14.48"
  },
  "packageManager": "bun@1.3.8"
}
